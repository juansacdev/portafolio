---
import '../styles/global.css';
import SiteHeader from '../components/organisms/SiteHeader.astro';
import SiteFooter from '../components/organisms/SiteFooter.astro';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** URL of this same page in the other language. */
  altUrl: string;
}

const { locale, title, description, altUrl } = Astro.props;
const altLocale: Locale = locale === 'es' ? 'en' : 'es';
const homeUrl = locale === 'es' ? '/' : '/en/';
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="alternate" hreflang={altLocale} href={altUrl} />
    <link rel="alternate" hreflang={locale} href={currentPath} />
    <title>{title}</title>

    <!-- Theme resolution before first paint, to avoid a flash of the wrong
         theme. localStorage wins; otherwise the OS preference applies. -->
    <script is:inline>
      (() => {
        const stored = localStorage.getItem('theme');
        const theme =
          stored === 'dark' || stored === 'light'
            ? stored
            : window.matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
        document.documentElement.dataset.theme = theme;
      })();
    </script>
  </head>
  <body>
    <SiteHeader locale={locale} altUrl={altUrl} homeUrl={homeUrl} />

    <main>
      <slot />
    </main>

    <SiteFooter locale={locale} />
  </body>
</html>

<style>
  main {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
</style>
