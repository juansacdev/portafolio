---
import '../styles/global.css';
import SiteHeader from '../components/organisms/SiteHeader.astro';
import SiteFooter from '../components/organisms/SiteFooter.astro';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  /** URL of this same page in the other language. */
  altUrl: string;
}

const { locale, title, description, altUrl } = Astro.props;
const altLocale: Locale = locale === 'es' ? 'en' : 'es';
const homeUrl = locale === 'es' ? '/' : '/en/';
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" hreflang={altLocale} href={altUrl} />
    <link rel="alternate" hreflang={locale} href={currentPath} />
    <title>{title}</title>

    <!-- Theme resolution before first paint, to avoid a flash of the wrong
         theme. Three modes: 'system' (default, follows the OS live),
         'light', and 'dark'. The resolved theme lands in data-theme; the
         chosen mode in data-theme-mode (used by the toggle icon). -->
    <script is:inline>
      (() => {
        const media = window.matchMedia('(prefers-color-scheme: dark)');

        const apply = () => {
          const stored = localStorage.getItem('theme-mode');
          const mode = stored === 'dark' || stored === 'light' ? stored : 'system';
          const theme = mode === 'system' ? (media.matches ? 'dark' : 'light') : mode;
          document.documentElement.dataset.themeMode = mode;
          document.documentElement.dataset.theme = theme;
        };

        apply();
        media.addEventListener('change', apply);
        window.applyTheme = apply;
      })();
    </script>
  </head>
  <body>
    <SiteHeader locale={locale} altUrl={altUrl} homeUrl={homeUrl} />

    <main>
      <slot />
    </main>

    <SiteFooter locale={locale} />
  </body>
</html>

<style>
  main {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: 1.5rem;
  }
</style>
