---
import type { ExperienceEntry } from '../../data/profile';
import { emphasize } from '../../utils/emphasize';

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
---

<article class="experience-item">
  <header class="experience-header">
    <h3>{entry.role} · {entry.company}</h3>
    <p class="period">
      <time datetime={entry.start}>{entry.period.split(' – ')[0]}</time>
      {' – '}
      <time datetime={entry.end}>{entry.period.split(' – ')[1]}</time>
    </p>
  </header>


  <p class="summary">{entry.summary}</p>

  {
    entry.paragraphs ? (
      entry.paragraphs.map((paragraph) => (
        <p class="narrative" set:html={emphasize(paragraph)} />
      ))
    ) : (
      <ul class="bullets">
        {(entry.bullets ?? []).map((bullet) => (
          <li set:html={emphasize(bullet)} />
        ))}
      </ul>
    )
  }
</article>

<style>
  /* Timeline: a vertical rail on the left with a dot per entry.
     Rail center, dot center, and section-icon center must share the same
     x. The dot's inset is measured from the padding box (the rail border
     sits outside it), hence -9px instead of -7px. Values verified against
     rendered pixels. */
  .experience-item {
    position: relative;
    margin-inline-start: 14.5px;
    padding-inline-start: 1.75rem;
    padding-block-end: 3rem; /* 48px between entries */
    border-inline-start: 2px solid var(--color-border);
  }

  .experience-item:last-child {
    padding-block-end: 0.5rem;
  }

  .experience-item::before {
    content: '';
    position: absolute;
    inset-inline-start: -9px;
    inset-block-start: 0.25rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--color-accent);
    border: 3px solid var(--color-bg);
  }

  .experience-header {
    margin-block-end: 0.5rem;
  }

  h3 {
    font-size: 1.25rem; /* 20px */
    margin: 0;
  }

  .period {
    margin: 0.15rem 0 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .summary {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .narrative:last-child {
    margin-block-end: 0;
  }

  .narrative :global(strong) {
    color: var(--color-accent);
    font-weight: 600;
  }

  .bullets {
    margin-block: 0;
    padding-inline-start: 1.2rem;
    display: grid;
    gap: 0.5rem;
  }

  .bullets :global(strong) {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
