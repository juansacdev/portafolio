---
import type { ExperienceEntry } from '../../data/profile';
import { emphasize } from '../../utils/emphasize';

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
---

<article class="experience-item">
  <header class="experience-header">
    <h3>{entry.role}</h3>
    <p class="period">
      <time datetime={entry.start}>{entry.period}</time>
    </p>
  </header>

  <p class="company-line">
    {entry.sector ? `${entry.company} – ${entry.sector}` : entry.company}
  </p>

  <ul class="bullets">
    {entry.bullets.map((bullet) => (
      <li>{bullet}</li>
    ))}
  </ul>

  {entry.note && <p class="note" set:html={emphasize(entry.note)} />}
</article>

<style>
  /* Timeline: a vertical rail on the left with a dot per entry.
     Rail center, dot center, and section-icon center must share the same
     x. The dot's inset is measured from the padding box (the rail border
     sits outside it), hence -9px instead of -7px. Values verified against
     rendered pixels. */
  .experience-item {
    position: relative;
    margin-inline-start: 14.5px;
    padding-inline-start: 1.75rem;
    padding-block-end: 3rem; /* 48px between entries */
    border-inline-start: 2px solid var(--color-border);
  }

  .experience-item:last-child {
    padding-block-end: 0.5rem;
    /* Fade the rail out toward the bottom on the final entry. */
    border-image: linear-gradient(
        to bottom,
        var(--color-border) 35%,
        transparent 100%
      )
      1;
  }

  .experience-item::before {
    content: '';
    position: absolute;
    inset-inline-start: -9px;
    inset-block-start: 0.25rem;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background-color: var(--color-accent);
    border: 3px solid var(--color-bg);
  }

  .experience-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem 1rem;
    margin-block-end: 0.3rem;
  }

  h3 {
    font-size: 1.25rem; /* 20px */
    font-weight: 700;
    margin: 0;
  }

  .period {
    margin: 0;
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .company-line {
    margin: 0 0 0.85rem;
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .bullets {
    margin-block: 0;
    padding-inline-start: 1.2rem;
    display: grid;
    gap: 0.5rem;
  }

  .note {
    margin-block: 0.85rem 0;
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .note :global(a) {
    color: var(--color-accent);
  }
</style>
