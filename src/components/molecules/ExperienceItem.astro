---
import TagList from './TagList.astro';
import type { ExperienceEntry } from '../../data/profile';

interface Props {
  entry: ExperienceEntry;
}

const { entry } = Astro.props;
---

<article class="experience-item">
  <header class="experience-header">
    <h3>{entry.role} · {entry.company}</h3>
    <p class="period">
      <time datetime={entry.start}>{entry.period.split(' – ')[0]}</time>
      {' – '}
      <time datetime={entry.end}>{entry.period.split(' – ')[1]}</time>
    </p>
  </header>

  <p class="summary">{entry.summary}</p>

  <ul class="bullets">
    {entry.bullets.map((bullet) => <li>{bullet}</li>)}
  </ul>

  <TagList tags={entry.stack} />
</article>

<style>
  .experience-item {
    padding-block-end: 2.25rem;
  }

  .experience-item:not(:last-child) {
    border-block-end: 1px solid var(--color-border);
    margin-block-end: 2.25rem;
  }

  .experience-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.25rem 1rem;
    margin-block-end: 0.5rem;
  }

  h3 {
    font-size: 1.125rem;
    margin: 0;
  }

  .period {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    white-space: nowrap;
  }

  .summary {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .bullets {
    margin-block: 0 1rem;
    padding-inline-start: 1.2rem;
    display: grid;
    gap: 0.5rem;
  }
</style>
