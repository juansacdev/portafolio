---
import TagList from './TagList.astro';
import type { Project } from '../../data/profile';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const hasLinks = project.repoUrl || project.liveUrl;
---

<article class="project-card">
  <h3>{project.name}</h3>

  {project.description.map((paragraph) => <p>{paragraph}</p>)}

  <TagList tags={project.stack} />

  {
    hasLinks && (
      <footer class="links">
        {project.repoUrl && (
          <a class="btn" href={project.repoUrl} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 16 16" aria-hidden="true">
              <path
                d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27s1.36.09 2 .27c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8z"
              />
            </svg>
            Code
          </a>
        )}
        {project.liveUrl && (
          <a class="btn" href={project.liveUrl} target="_blank" rel="noopener noreferrer">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M6.5 3.5h-3a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1v-3" />
              <path d="M9.5 2.5h4v4" />
              <path d="M13.5 2.5 7 9" />
            </svg>
            Preview
          </a>
        )}
      </footer>
    )
  }
</article>

<style>
  .project-card {
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  h3 {
    font-size: 1.125rem;
    margin-block: 0 0.75rem;
  }

  p {
    font-size: 0.95rem;
  }

  p:last-of-type {
    margin-block-end: 1rem;
  }

  /* Pin tags (and buttons below them) to the card's bottom edge, so
     sibling cards with different text lengths stay aligned. */
  .project-card :global(.tag-list) {
    margin-block-start: auto;
  }

  .links {
    display: flex;
    gap: 0.75rem;
    margin-block-start: 1.25rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.35rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background-color: var(--color-button-bg);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease,
      border-color 0.15s ease;
  }

  .btn:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: transparent;
  }

  .btn svg {
    width: 1.05em;
    height: 1.05em;
    fill: currentColor;
  }

  .btn svg[fill='none'] {
    fill: none;
  }
</style>
