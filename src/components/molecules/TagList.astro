---
import Tag from '../atoms/Tag.astro';

interface Props {
  tags: string[];
}

const { tags } = Astro.props;
---

<ul class="tag-list">
  {tags.map((tag) => <Tag label={tag} />)}
</ul>

<style>
  .tag-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin: 0;
    padding: 0;
  }
</style>
