---
import Icon from './Icon.astro';

interface Props {
  id?: string;
  icon?: 'briefcase' | 'code' | 'pen' | 'user' | 'mail';
}

const { id, icon } = Astro.props;
---

<h2 class="section-title" id={id}>
  {icon && <Icon name={icon} />}
  <slot />
</h2>

<style>
  .section-title {
    font-size: 1.5rem;
    margin-block: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title :global(.icon) {
    color: var(--color-accent);
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: var(--color-border);
  }
</style>
