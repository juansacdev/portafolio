---
import Icon from './Icon.astro';

interface Props {
  id?: string;
  icon?: 'briefcase' | 'code' | 'pen' | 'user' | 'mail';
}

const { id, icon } = Astro.props;
---

<h2 class="section-title" id={id}>
  {icon && <Icon name={icon} size={25} />}
  <slot />
</h2>

<style>
  .section-title {
    font-size: 1.5rem;
    margin-block: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  /* Same color as the heading text: white in dark mode, near-black in
     light mode (pure white would vanish on the light background). */
  .section-title :global(.icon) {
    color: var(--color-text);
  }

  /* Same soft fade as the navbar line, but only toward the right edge. */
  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--color-border), transparent);
  }
</style>
