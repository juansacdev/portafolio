---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<li class="tag">{label}</li>

<style>
  .tag {
    display: inline-block;
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    border: 1px solid var(--color-line);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    white-space: nowrap;
  }
</style>
