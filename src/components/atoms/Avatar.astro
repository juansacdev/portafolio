---
import { Image } from 'astro:assets';
import avatar from '../../assets/pfp.png';

interface Props {
  alt: string;
  size?: number;
}

const { alt, size = 128 } = Astro.props;
---

<Image
  src={avatar}
  alt={alt}
  width={size}
  height={size}
  loading="eager"
  class="avatar"
/>

<style>
  .avatar {
    border-radius: 50%;
    border: 3px solid var(--color-border);
  }
</style>
