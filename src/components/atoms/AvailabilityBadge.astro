---
import type { Locale } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { identity } from '../../data/profile';

interface Props {
  locale: Locale;
  /** Visual effect: 'default' (dot only), 'pulse' (expanding ring), 'shimmer' (light sweep). */
  variant?: 'default' | 'pulse' | 'shimmer';
}

const { locale, variant = 'default' } = Astro.props;
---

<a
  class:list={['availability', variant]}
  href={identity.linkedin}
  target="_blank"
  rel="noopener noreferrer"
>
  <span class="dot" aria-hidden="true"></span>
  {t(locale, 'hero.available')}
</a>

<style>
  .availability {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.25rem 0.8rem;
    border-radius: 999px;
    background-color: var(--color-available-bg);
    color: var(--color-available);
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid transparent;
    transition: border-color 0.15s ease;
  }

  .availability:hover {
    color: var(--color-available);
    border-color: var(--color-available);
  }

  .dot {
    width: 0.55rem;
    height: 0.55rem;
    border-radius: 50%;
    background-color: var(--color-available);
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  /* Variant: expanding ring around the whole badge. */
  .pulse {
    animation: badge-ring 2s ease-out infinite;
  }

  @keyframes badge-ring {
    0% {
      box-shadow: 0 0 0 0
        color-mix(in srgb, var(--color-available) 45%, transparent);
    }
    70%,
    100% {
      box-shadow: 0 0 0 10px transparent;
    }
  }

  /* Variant: a light sweeping from side to side. */
  .shimmer {
    position: relative;
    overflow: hidden;
  }

  .shimmer::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      110deg,
      transparent 25%,
      color-mix(in srgb, var(--color-available) 30%, transparent) 50%,
      transparent 75%
    );
    transform: translateX(-100%);
    animation: badge-shine 2.4s ease-in-out infinite;
  }

  @keyframes badge-shine {
    to {
      transform: translateX(100%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .dot,
    .pulse {
      animation: none;
    }

    .shimmer::after {
      animation: none;
    }
  }
</style>
