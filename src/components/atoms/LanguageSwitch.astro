---
import type { Locale } from '../../i18n/ui';

interface Props {
  /** URL of the equivalent page in the other language. */
  href: string;
  targetLocale: Locale;
  label: string;
  shortLabel: string;
}

const { href, targetLocale, label, shortLabel } = Astro.props;
---

<a
  class="lang-switch"
  href={href}
  hreflang={targetLocale}
  lang={targetLocale}
  aria-label={label}
  title={label}
>
  {shortLabel}
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 2.25rem;
    padding-inline: 0.65rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background-color: var(--color-surface);
    color: var(--color-text);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .lang-switch:hover {
    color: var(--color-accent-strong);
    border-color: var(--color-accent);
  }
</style>
