---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<button type="button" class="theme-toggle" aria-label={label} title={label}>
  <svg
    class="icon-system"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <rect x="2" y="3" width="20" height="14" rx="2"></rect>
    <path d="M8 21h8m-4-4v4"></path>
  </svg>
  <svg
    class="icon-sun"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      d="M12 2v2m0 16v2M4.93 4.93l1.41 1.41m11.32 11.32 1.41 1.41M2 12h2m16 0h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
    ></path>
  </svg>
  <svg
    class="icon-moon"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<script>
  // Cycle: system → light → dark → system. The inline script in the layout
  // owns the resolution logic and exposes it as window.applyTheme.
  const CYCLE: Record<string, string> = {
    system: 'light',
    light: 'dark',
    dark: 'system',
  };

  for (const button of document.querySelectorAll<HTMLButtonElement>('.theme-toggle')) {
    button.addEventListener('click', () => {
      const current = document.documentElement.dataset.themeMode ?? 'system';
      const next = CYCLE[current] ?? 'system';

      if (next === 'system') {
        localStorage.removeItem('theme-mode');
      } else {
        localStorage.setItem('theme-mode', next);
      }

      (window as Window & { applyTheme?: () => void }).applyTheme?.();
    });
  }
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.9rem;
    height: 1.9rem;
    padding: 0;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: var(--color-button-bg);
    color: var(--color-text);
    cursor: pointer;
    transition: background-color 0.15s ease, color 0.15s ease,
      border-color 0.15s ease;
  }

  .theme-toggle:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: transparent;
  }

  .theme-toggle svg {
    width: 1rem;
    height: 1rem;
  }

  /* Show only the icon of the current mode. */
  svg {
    display: none;
  }

  :global([data-theme-mode='system']) .icon-system {
    display: block;
  }

  :global([data-theme-mode='light']) .icon-sun {
    display: block;
  }

  :global([data-theme-mode='dark']) .icon-moon {
    display: block;
  }
</style>
