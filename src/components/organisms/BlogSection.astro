---
import SectionTitle from '../atoms/SectionTitle.astro';
import BlogCard from '../molecules/BlogCard.astro';
import type { Locale } from '../../i18n/ui';
import { t, anchors } from '../../i18n/ui';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const posts = (await getCollection('blog', ({ data }) => data.lang === locale))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const blogBase = locale === 'es' ? '/blog' : '/en/blog';
---

<section class="blog" aria-labelledby={anchors[locale].blog}>
  <SectionTitle id={anchors[locale].blog}>
    {t(locale, 'section.blog')}
  </SectionTitle>

  <div class="post-list">
    {
      posts.map((post) => (
        <BlogCard
          locale={locale}
          url={`${blogBase}/${post.data.slug}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          readingTime={post.data.readingTime}
          tags={post.data.tags}
        />
      ))
    }
  </div>
</section>

<style>
  .blog {
    padding-block-start: var(--space-section);
  }

  .post-list {
    display: grid;
    gap: 1.25rem;
  }
</style>
