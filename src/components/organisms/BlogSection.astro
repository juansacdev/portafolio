---
import SectionTitle from '../atoms/SectionTitle.astro';
import BlogCard from '../molecules/BlogCard.astro';
import type { Locale } from '../../i18n/ui';
import { t, anchors } from '../../i18n/ui';
import { getCollection } from 'astro:content';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;

const LATEST_COUNT = 3;

const allPosts = (
  await getCollection(
    'blog',
    ({ data }) => data.lang === locale && data.status === 'published'
  )
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const posts = allPosts.slice(0, LATEST_COUNT);

const blogBase = locale === 'es' ? '/blog' : '/en/blog';
---

{posts.length > 0 && (
<section class="blog" aria-labelledby={anchors[locale].blog}>
  <SectionTitle id={anchors[locale].blog}>
    {t(locale, 'section.blog')}
  </SectionTitle>

  <div class="post-list">
    {
      posts.map((post) => (
        <BlogCard
          locale={locale}
          url={`${blogBase}/${post.data.slug}/`}
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          readingTime={post.data.readingTime}
          tags={post.data.tags}
        />
      ))
    }
  </div>

  <a class="view-all" href={`${blogBase}/`}>
    {t(locale, 'blog.viewAll')} →
  </a>
</section>
)}

<style>
  .blog {
    padding-block-start: var(--space-section);
  }

  .post-list {
    display: grid;
    gap: 1.25rem;
  }

  .view-all {
    display: inline-flex;
    align-items: center;
    margin-block-start: 1.5rem;
    padding: 0.28rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background-color: var(--color-button-bg);
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease,
      border-color 0.15s ease;
  }

  .view-all:hover {
    background-color: var(--color-text);
    color: var(--color-bg);
    border-color: transparent;
  }
</style>
