---
import SectionTitle from '../atoms/SectionTitle.astro';
import Avatar from '../atoms/Avatar.astro';
import type { Locale } from '../../i18n/ui';
import { t, anchors } from '../../i18n/ui';
import { content, identity } from '../../data/profile';
import { emphasize } from '../../utils/emphasize';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { about, skills } = content[locale];
const cvHref =
  locale === 'es'
    ? '/cv/CV-Juan-Sebastian-Agudelo.es.pdf'
    : '/cv/CV-Juan-Sebastian-Agudelo.pdf';
---

<section class="about" aria-labelledby={anchors[locale].about}>
  <SectionTitle id={anchors[locale].about}>
    {t(locale, 'section.about')}
  </SectionTitle>

  <div class="grid">
    <div class="aside">
      <Avatar alt={t(locale, 'a11y.avatarAlt')} size={220} />
      <a class="cv-btn" href={cvHref} download>{t(locale, 'about.downloadCv')}</a>
      <div class="soc">
        <a href={`mailto:${identity.email}`}>{identity.email}</a>
        <a href={identity.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>
        <a href={identity.github} target="_blank" rel="noopener noreferrer">Github</a>
      </div>
    </div>

    <div class="body">
      {about.map((paragraph) => <p set:html={emphasize(paragraph)} />)}

      <div class="skills">
        <h3>{t(locale, 'skills.title')}</h3>
        <dl class="skill-list">
          {
            skills.map((group) => (
              <div class="skill-row">
                <dt>{group.area}</dt>
                <dd>{group.items.join(' · ')}</dd>
              </div>
            ))
          }
        </dl>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding-block-start: var(--space-section);
  }

  .grid {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 3rem;
    align-items: start;
  }

  .aside :global(img) {
    border-radius: 14px;
  }

  .soc {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem 1rem;
    margin-block-start: 1rem;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
  }

  .soc a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .soc a:hover {
    color: var(--color-accent);
  }

  .body p {
    max-width: 75ch;
  }

  .body p :global(strong) {
    color: inherit;
    font-weight: inherit;
  }

  .skills {
    margin-block-start: 2rem;
  }

  .skills h3 {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    margin: 0 0 1rem;
  }

  .skill-list {
    margin: 0;
    border-block-end: 1px solid var(--color-line-soft);
  }

  .skill-row {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: 1.5rem;
    align-items: baseline;
    padding-block: 0.6rem;
    border-block-start: 1px solid var(--color-line-soft);
  }

  .skill-row dt {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
  }

  .skill-row dd {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .cv-btn {
    display: block;
    margin-block-start: 1rem;
    padding: 0.55rem 1rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    color: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: 10px;
    text-decoration: none;
  }

  .cv-btn:hover {
    background-color: var(--color-accent);
    color: var(--color-bg);
  }

  @media (max-width: 48rem) {
    .grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
    }

    .aside {
      max-width: 200px;
    }

    .skill-row {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }
  }
</style>
