---
import SectionTitle from '../atoms/SectionTitle.astro';
import type { Locale } from '../../i18n/ui';
import { t, anchors } from '../../i18n/ui';
import { content } from '../../data/profile';
import { emphasize } from '../../utils/emphasize';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { about } = content[locale];
---

<section class="about" aria-labelledby={anchors[locale].about}>
  <SectionTitle id={anchors[locale].about} icon="user">
    {t(locale, 'section.about')}
  </SectionTitle>

  {about.map((paragraph) => <p set:html={emphasize(paragraph)} />)}
</section>

<style>
  .about {
    padding-block-start: var(--space-section);
  }

  p {
    max-width: 40rem;
  }

  p :global(strong) {
    color: var(--color-accent);
    font-weight: 600;
  }
</style>
