---
import type { Locale } from '../../i18n/ui';
import { t, anchors } from '../../i18n/ui';
import { content, identity } from '../../data/profile';
import { emphasize } from '../../utils/emphasize';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { hero } = content[locale];
const a = anchors[locale];
---

<section class="hero">
  <p class="kicker">{hero.role} · {identity.location}</p>
  <h1 set:html={emphasize(hero.headline)} />

  <div class="lede">
    {hero.lede.map((line) => <p set:html={emphasize(line)} />)}
  </div>

  <div class="cta-group">
    <a class="cta" href={`mailto:${identity.email}`}>{t(locale, 'hero.talk')} →</a>
    {/* <a class="cta-2" href={`#${a.caseStudy}`}>{t(locale, 'hero.seeCase')} ↓</a> */}
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-hero) 0;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0 0 1.1rem;
  }

  h1 {
    font-size: clamp(2.1rem, 5.2vw, 3.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.07;
    margin: 0 0 1.6rem;
    max-width: 22ch;
  }

  h1 :global(em) {
    font-style: normal;
    color: var(--color-accent);
  }

  .lede {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    max-width: 58ch;
  }

  .lede :global(p) {
    margin: 0 0 0.95rem;
  }

  .lede :global(p:last-child) {
    margin-bottom: 0;
  }

  .lede :global(strong) {
    color: var(--color-text);
    font-weight: 600;
  }

  .lede :global(a) {
    color: var(--color-accent);
  }

  .cta-group {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.1rem;
    margin-block-start: 2rem;
  }

  .cta {
    display: inline-block;
    background-color: var(--color-accent);
    color: var(--color-on-accent);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    padding: 0.75rem 1.4rem;
    border-radius: 10px;
    transition: background-color 0.15s ease;
  }

  .cta:hover {
    background-color: var(--color-accent-strong);
  }

  .cta-2 {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .cta-2:hover {
    color: var(--color-accent);
  }
</style>
