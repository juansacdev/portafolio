---
import Avatar from '../atoms/Avatar.astro';
import AvailabilityBadge from '../atoms/AvailabilityBadge.astro';
import ContactLinks from '../molecules/ContactLinks.astro';
import type { Locale } from '../../i18n/ui';
import { t } from '../../i18n/ui';
import { content, identity } from '../../data/profile';
import { emphasize } from '../../utils/emphasize';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const { hero } = content[locale];
---

<section class="hero">
  <div class="hero-top">
    <Avatar alt={t(locale, 'a11y.avatarAlt')} size={128} />

    <div class="hero-heading">
      <AvailabilityBadge locale={locale} variant="shimmer" />
      <h1 set:html={emphasize(hero.title)} />
      <p class="role">{hero.role} · {identity.location}</p>
    </div>
  </div>

  <div class="hero-body">
    {hero.tagline.map((line) => <p class="tagline" set:html={emphasize(line)} />)}

    <ContactLinks locale={locale} />
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-hero) 0;
  }

  .hero-top {
    display: flex;
    align-items: center;
    gap: 2rem;
    margin-block-end: 2.75rem;
  }

  .hero-heading > :global(.availability) {
    margin-block-end: 0.9rem;
  }

  h1 {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    margin-block: 0 0.25rem;
  }

  h1 :global(strong) {
    color: var(--color-accent);
  }

  .role {
    color: var(--color-text-muted);
    font-weight: 500;
    margin-block: 0;
  }

  .tagline {
    max-width: 38rem;
  }

  .tagline :global(strong) {
    color: var(--color-accent);
    font-weight: 600;
  }

  .hero-body > :global(address) {
    margin-block-start: 2.25rem;
  }

  @media (max-width: 40rem) {
    .hero-top {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }
</style>
