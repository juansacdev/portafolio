---
import ThemeToggle from '../atoms/ThemeToggle.astro';
import LanguageSwitch from '../atoms/LanguageSwitch.astro';
import type { Locale } from '../../i18n/ui';
import { t, anchors } from '../../i18n/ui';

interface Props {
  locale: Locale;
  /** URL of this same page in the other language. */
  altUrl: string;
  /** Base path of the homepage in the current language ('/' or '/en/'). */
  homeUrl: string;
}

const { locale, altUrl, homeUrl } = Astro.props;
const targetLocale: Locale = locale === 'es' ? 'en' : 'es';
const a = anchors[locale];
---

<header class="site-header">
  <div class="inner">
    <nav aria-label={t(locale, 'nav.label')}>
      <ul class="nav-list">
        <li><a href={`${homeUrl}#${a.experience}`}>{t(locale, 'nav.experience')}</a></li>
        <li><a href={`${homeUrl}#${a.projects}`}>{t(locale, 'nav.projects')}</a></li>
        <li><a href={`${homeUrl}#${a.blog}`}>{t(locale, 'nav.blog')}</a></li>
        <li><a href={`${homeUrl}#${a.about}`}>{t(locale, 'nav.about')}</a></li>
      </ul>
    </nav>

    <span class="divider" aria-hidden="true"></span>

    <div class="controls">
      <LanguageSwitch
        href={altUrl}
        targetLocale={targetLocale}
        label={t(locale, 'lang.switch')}
        shortLabel={t(locale, 'lang.switchShort')}
      />
      <ThemeToggle label={t(locale, 'theme.toggle')} />
    </div>
  </div>
</header>

<script>
  // Bottom line: only visible once the page is scrolled.
  const header = document.querySelector<HTMLElement>('.site-header');

  if (header) {
    const onScroll = () => {
      header.toggleAttribute('data-scrolled', window.scrollY > 8);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Scrollspy: highlight the nav link of the section currently in view.
  // Only runs on pages whose nav anchors point to the current path.
  const links = new Map<string, HTMLAnchorElement>();

  for (const link of document.querySelectorAll<HTMLAnchorElement>('.nav-list a')) {
    const url = new URL(link.href);
    if (url.pathname === location.pathname && url.hash) {
      links.set(url.hash.slice(1), link);
    }
  }

  if (links.size > 0) {
    const setActive = (id: string) => {
      for (const [anchorId, link] of links) {
        if (anchorId === id) {
          link.setAttribute('aria-current', 'true');
        } else {
          link.removeAttribute('aria-current');
        }
      }
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            const heading = entry.target.querySelector('[id]');
            if (heading) setActive(heading.id);
          }
        }
      },
      // A horizontal band at 20% from the top decides the active section.
      { rootMargin: '-15% 0px -75% 0px' }
    );

    for (const id of links.keys()) {
      const section = document.getElementById(id)?.closest('section');
      if (section) observer.observe(section);
    }
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: color-mix(in srgb, var(--color-bg) 85%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  /* Soft, partial-width bottom line — fades in only after scrolling. */
  .site-header::after {
    content: '';
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    margin-inline: auto;
    width: min(80%, var(--max-width));
    height: 1px;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-border) 25%,
      var(--color-border) 75%,
      transparent
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .site-header[data-scrolled]::after {
    opacity: 1;
  }

  .inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem 1rem;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: 0.85rem 1.5rem;
  }

  .nav-list {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem 0.35rem;
    margin: 0;
    padding: 0;
  }

  .nav-list a {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: 0.95rem;
    padding: 0.3rem 0.8rem;
    border-radius: 999px;
    transition: color 0.15s ease, background-color 0.15s ease;
  }

  .nav-list a:hover {
    color: var(--color-accent-strong);
  }

  .nav-list a[aria-current='true'] {
    background-color: var(--color-tag-bg);
    color: var(--color-tag-text);
    font-weight: 600;
  }

  .divider {
    width: 1px;
    height: 1.4rem;
    background-color: var(--color-text-muted);
    opacity: 0.6;
  }

  .controls {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  @media (max-width: 40rem) {
    .inner {
      justify-content: space-between;
    }
  }
</style>
