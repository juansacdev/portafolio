---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/organisms/Hero.astro';
// import CaseStudySection from '../../components/organisms/CaseStudySection.astro';
import ExperienceSection from '../../components/organisms/ExperienceSection.astro';
import ProjectsSection from '../../components/organisms/ProjectsSection.astro';
import BlogSection from '../../components/organisms/BlogSection.astro';
import AboutSection from '../../components/organisms/AboutSection.astro';
import { t } from '../../i18n/ui';
import { identity } from '../../data/profile';

const locale = 'es';
---

<BaseLayout
  locale={locale}
  title={`${identity.name} — Software Engineer`}
  description={t(locale, 'meta.description')}
  altUrl="/"
>
  <Hero locale={locale} />
  {/* <CaseStudySection locale={locale} /> */}
  <ExperienceSection locale={locale} />
  <ProjectsSection locale={locale} />
  <BlogSection locale={locale} />
  <AboutSection locale={locale} />
</BaseLayout>
