---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../components/organisms/BlogPost.astro';
import { identity } from '../../data/profile';

export async function getStaticPaths() {
  // Drafts get no page at all; unlisted and published are accessible.
  const posts = await getCollection(
    'blog',
    ({ data }) => data.lang === 'en' && data.status !== 'draft'
  );
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout
  locale="en"
  title={`${post.data.title} — ${identity.name}`}
  description={post.data.description}
  altUrl={`/es/blog/${post.data.translationSlug}/`}
>
  <BlogPost locale="en" post={post} />
</BaseLayout>
