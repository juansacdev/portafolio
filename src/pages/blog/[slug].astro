---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPost from '../../components/organisms/BlogPost.astro';
import { identity } from '../../data/profile';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'es');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
---

<BaseLayout
  locale="es"
  title={`${post.data.title} — ${identity.name}`}
  description={post.data.description}
  altUrl={`/en/blog/${post.data.translationSlug}/`}
>
  <BlogPost locale="es" post={post} />
</BaseLayout>
